NEXT_PUBLIC_PB_URL=http://localhost:8090
# Proveedor del modelo con visión usado para extraer datos de recibos (ver
# web/app/api/extract-receipt/route.ts). El slug de modelo es específico de
# OpenRouter (formato "proveedor/modelo") — revisa openrouter.ai/models antes
# de cambiarlo.
OPENROUTER_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxx
OPENROUTER_MODEL=anthropic/claude-sonnet-4.5
# Credenciales del usuario de la app (colección `users`, no el superusuario), usadas
# server-side por /api/mcp para validar API keys y consultar gastos en nombre del usuario.
PB_APP_EMAIL=tu-correo@ejemplo.com
PB_APP_PASSWORD=tu-contraseña
